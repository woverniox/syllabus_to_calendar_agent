# ==============================================================================
# SYLLABUS TO CALENDAR AGENT - SOPS/YAML TEMPLATE
# ==============================================================================
# This matches the 'google_secrets: |' block in your encrypted secrets.yaml.
# When decrypted, this entire block is often mapped to /run/secrets/google_secrets.

google_secrets: |
    # Google OAuth - Cloud Console
    GOOGLE_CLIENT_ID="your_id.apps.googleusercontent.com"
    GOOGLE_CLIENT_SECRET="your_secret"
    GOOGLE_REFRESH_TOKEN="your_token"
    GOOGLE_TOKEN=""

    # LLM Config
    GEMINI_API_KEY="your_key_here"

    # Database & Redis
    DATABASE_URL="sqlite:///./syllabus_agent.db"
    DB_PASSWORD="securedblol"
    REDIS_URL="redis://localhost:6379"

